# Shared default
VITE_USE_DEMO_DATA=false

# Development (`npm run dev`)
VITE_PROXY_TARGET=http://localhost:8080

# Production build (`npm run build`)
# Leave blank when CloudFront routes `/api` to the backend.
VITE_API_BASE_URL=

# Toss Payments browser client key. Never put the secret key in frontend env.
VITE_TOSS_CLIENT_KEY=test_ck_여기에_토스_클라이언트키_입력
