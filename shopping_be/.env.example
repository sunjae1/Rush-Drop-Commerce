# === AWS S3 설정 ===
AWS_ACCESS_KEY=여기에_액세스키_입력
AWS_SECRET_KEY=여기에_시크릿키_입력
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=여기에_버킷이름_입력
AWS_S3_PRESIGNED_EXPIRATION=60

# [Compose] 운영 compose에서 사용할 이미지
APP_IMAGE=[이름]/shopping-app:latest

# === DB 설정 ===
DB_URL=jdbc:mysql://localhost:3306/myshopping
DB_USERNAME=root
DB_PASSWORD=your_password

# === CORS 설정 ===
# 프론트엔드 주소를 쉼표로 여러 개 넣을 수 있습니다. (예: https://shop.example.com,https://admin.example.com)
FRONT_END_ORIGIN=localhost:5173

# === JWT 설정 ===
# 32자 이상 랜덤 문자열을 넣어주세요. 예: PowerShell에서
# [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_ACCESS_SECRET=32자_이상_랜덤_문자열_입력
ACCESS_TOKEN_EXPIRE=5m
REFRESH_TOKEN_EXPIRE=14d
JWT_ISSUER=shopping-api

# === Redis 설정 ===
# 백엔드를 로컬에서 실행하면 localhost, docker compose로 앱까지 같이 실행하면 redis 를 사용하세요.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# === Toss Payments 테스트 결제 ===
# 클라이언트 키는 프론트엔드 .env에만 넣고, 시크릿 키는 백엔드에만 넣습니다.
TOSS_SECRET_KEY=test_sk_여기에_토스_시크릿키_입력
TOSS_API_BASE_URL=https://api.tosspayments.com

# === Cookie 설정 ===
ACCESS_TOKEN_COOKIE_NAME=ACCESS_TOKEN
REFRESH_TOKEN_COOKIE_NAME=REFRESH_TOKEN
ACCESS_TOKEN_COOKIE_PATH=/api
REFRESH_TOKEN_COOKIE_PATH=/api/auth
#.sunjae.link과 같이 도메인 앞에 점(.)을 붙이면 모든 하위 도메인에서 쿠키를 사용할 수 있습니다.
COOKIE_DOMAIN=
# 운영 환경에서는 true로 설정하세요. 개발 환경에서는 false로 설정할 수 있습니다.
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax



